import React, { createContext, useContext, useState, useEffect } from 'react';
import AsyncStorage from '@react-native-async-storage/async-storage';

const AuthContext = createContext();

// Storage keys
const STORAGE_KEYS = {
  USERS: 'troupe_users',
  CURRENT_USER: 'troupe_current_user',
  LOGGED_IN: 'troupe_logged_in',
  TROUPES: 'troupe_troupes',
  STATS: 'troupe_stats',
};

export function AuthProvider({ children }) {
  const [user, setUser] = useState(null);
  const [users, setUsers] = useState([]);
  const [troupes, setTroupes] = useState([]);
  const [stats, setStats] = useState({ gems: 100, streak: 0, minutes: 0, sessions: 0 });
  const [isLoading, setIsLoading] = useState(true);
  const [isLoggedIn, setIsLoggedIn] = useState(false);

  useEffect(() => {
    loadAllData();
  }, []);

  async function loadAllData() {
    try {
      // Load users
      const storedUsers = await AsyncStorage.getItem(STORAGE_KEYS.USERS);
      if (storedUsers) setUsers(JSON.parse(storedUsers));
      
      // Load current user
      const storedUser = await AsyncStorage.getItem(STORAGE_KEYS.CURRENT_USER);
      if (storedUser) setUser(JSON.parse(storedUser));
      
      // Load troupes
      const storedTroupes = await AsyncStorage.getItem(STORAGE_KEYS.TROUPES);
      if (storedTroupes) setTroupes(JSON.parse(storedTroupes));
      
      // Load stats
      const storedStats = await AsyncStorage.getItem(STORAGE_KEYS.STATS);
      if (storedStats) setStats(JSON.parse(storedStats));
      
      // Load login status
      const loggedIn = await AsyncStorage.getItem(STORAGE_KEYS.LOGGED_IN);
      if (loggedIn === 'true' && storedUser) setIsLoggedIn(true);
      
    } catch (error) {
      console.error('Failed to load data:', error);
    } finally {
      setIsLoading(false);
    }
  }

  async function saveUsers(newUsers) {
    setUsers(newUsers);
    await AsyncStorage.setItem(STORAGE_KEYS.USERS, JSON.stringify(newUsers));
  }

  async function saveUser(newUser) {
    setUser(newUser);
    await AsyncStorage.setItem(STORAGE_KEYS.CURRENT_USER, JSON.stringify(newUser));
  }

  async function saveTroupes(newTroupes) {
    setTroupes(newTroupes);
    await AsyncStorage.setItem(STORAGE_KEYS.TROUPES, JSON.stringify(newTroupes));
  }

  async function saveStats(newStats) {
    setStats(newStats);
    await AsyncStorage.setItem(STORAGE_KEYS.STATS, JSON.stringify(newStats));
  }

  async function register(username, email, password) {
    // Check if email already exists
    if (users.find(u => u.email === email)) {
      throw new Error('Email already registered');
    }
    
    const newUser = {
      id: Date.now().toString(),
      username,
      email,
      password, // In production, hash this!
      avatar: '😊',
      avatarColor: '#6366F1',
      isPremium: false,
      createdAt: new Date().toISOString(),
    };
    
    await saveUsers([...users, newUser]);
    await saveUser(newUser);
    await AsyncStorage.setItem(STORAGE_KEYS.LOGGED_IN, 'true');
    setIsLoggedIn(true);
    
    return newUser;
  }

  async function login(email, password) {
    const foundUser = users.find(u => u.email === email && u.password === password);
    if (!foundUser) {
      throw new Error('Invalid email or password');
    }
    
    await saveUser(foundUser);
    await AsyncStorage.setItem(STORAGE_KEYS.LOGGED_IN, 'true');
    setIsLoggedIn(true);
    
    return foundUser;
  }

  async function logout() {
    await AsyncStorage.removeItem(STORAGE_KEYS.LOGGED_IN);
    setIsLoggedIn(false);
    setUser(null);
  }

  async function updateUser(updates) {
    const updatedUser = { ...user, ...updates };
    await saveUser(updatedUser);
    
    // Update in users array
    const updatedUsers = users.map(u => u.id === user.id ? updatedUser : u);
    await saveUsers(updatedUsers);
    
    return updatedUser;
  }

  async function updateStats(newStats) {
    await saveStats(newStats);
  }

  async function addTroupe(newTroupe) {
    await saveTroupes([...troupes, newTroupe]);
  }

  async function updateTroupe(updatedTroupe) {
    const updatedTroupes = troupes.map(t => t.id === updatedTroupe.id ? updatedTroupe : t);
    await saveTroupes(updatedTroupes);
  }

  return (
    <AuthContext.Provider
      value={{
        user,
        users,
        troupes,
        stats,
        isLoading,
        isLoggedIn,
        register,
        login,
        logout,
        updateUser,
        updateStats,
        addTroupe,
        updateTroupe,
      }}
    >
      {children}
    </AuthContext.Provider>
  );
}

export function useAuth() {
  const context = useContext(AuthContext);
  if (!context) {
    throw new Error('useAuth must be used within AuthProvider');
  }
  return context;
}
